# Base path for static hosting
# Vercel: leave as / (default)
# GitHub Pages project site: /grid-builder/
VITE_BASE_PATH=/

# OpenSymbols API root
# Vercel/local dev: /api/v2 (proxied by vercel.json or vite.config.ts)
# Direct (will fail in browser due to CORS): https://www.opensymbols.org/api/v2
VITE_OPENSYMBOLS_API=/api/v2
